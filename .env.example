# OpenAI API key — required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional model overrides (defaults shown)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Vercel KV — optional. When set, gallery and feedback are stored in KV
# instead of local .jsonl files. Required in multi-instance Vercel deployments.
# Create a KV store at https://vercel.com/storage/kv and copy the vars below.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
#
# For global rate limiting (replaces the per-instance in-memory limiter), also
# add an Upstash Redis database and swap in @upstash/ratelimit in the route.
